# Copy to .env, fill in, chmod 600. In production, compose passes env
# from /opt/deepmarks-repo/deploy/box-c/.env — this file is for local
# dev / smoke tests.

# ─── Relay the bunker subscribes to ─────────────────────────────────
# Production: strfry on Box A reached over the VPC.
BUNKER_RELAY_URL=ws://10.0.0.2:7777

# ─── Identity nsec files ────────────────────────────────────────────
# Files must be chmod 400, owned by the `bunker` user, containing either
# a bech32 nsec1… or a 64-char hex private key (single line).
BUNKER_BRAND_NSEC_PATH=/var/lib/deepmarks-bunker/nsecs/brand.nsec
BUNKER_PERSONAL_NSEC_PATH=/var/lib/deepmarks-bunker/nsecs/personal.nsec

# ─── Authorized client pubkey ───────────────────────────────────────
# The single payment-proxy pubkey this bunker will honor. Rotate by
# changing the value + restarting the container. Any sign_event request
# from a different pubkey is rejected + audited.
BUNKER_CLIENT_PUBKEY=

# ─── Audit log ──────────────────────────────────────────────────────
# Append-only JSONL. Parent dir must exist + be writable by the bunker
# user. Rotate with logrotate — never truncate live.
BUNKER_AUDIT_PATH=/var/log/deepmarks-bunker/audit.jsonl

# ─── Server ─────────────────────────────────────────────────────────
BUNKER_HOST=0.0.0.0
BUNKER_PORT=4100
LOG_LEVEL=info
NODE_ENV=production

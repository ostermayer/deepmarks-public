# ─── Redis (shared with Box A over VPC) ─────────────────────────────
# Private VPC IP of Box A. Archive worker connects to Box A's Redis
# over Linode's private network (no public exposure, no auth cost).
REDIS_URL=redis://10.0.0.5:6379

# ─── Blossom primary ─────────────────────────────────────────────────
# URL of our primary Blossom server. Archive worker uploads blobs
# here with BUD-01 auth, then issues a mirror fanout request.
BLOSSOM_PRIMARY_URL=https://blossom.deepmarks.org

# ─── Archive worker identity ─────────────────────────────────────────
# Dedicated Nostr key for this worker. Its pubkey must be in
# blossom-server's WRITE_ALLOWLIST_PUBKEYS env var so it can upload.
# Generate with: node -e "const k=require('nostr-tools').generateSecretKey(); console.log(Buffer.from(k).toString('hex'))"
ARCHIVE_WORKER_NSEC=

# ─── Payment-proxy callback ──────────────────────────────────────────
# Worker notifies payment-proxy when a job completes so it can
# update the user's archive record and, on failure, trigger a refund.
PAYMENT_PROXY_URL=http://payment-proxy:4000

# Shared secret for worker → payment-proxy callbacks. Any string;
# payment-proxy verifies it on incoming callbacks.
WORKER_CALLBACK_SECRET=

# ─── Rendering config ────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=4
PLAYWRIGHT_NAV_TIMEOUT_MS=30000
PLAYWRIGHT_RENDER_TIMEOUT_MS=60000
PLAYWRIGHT_VIEWPORT=1280x800
WAYBACK_MAX_AGE_DAYS=90

# ─── Queue config ────────────────────────────────────────────────────
# How often workers refresh their heartbeat on the active-job key.
# Box A supervisor reclaims jobs whose heartbeats go stale (>60s).
WORKER_HEARTBEAT_INTERVAL_MS=10000

# TTL for staged (intermediate) blobs in Redis. After this, a
# partially-processed job is discarded and the user can retry.
STAGED_BLOB_TTL_SECONDS=900

# ─── Observability ───────────────────────────────────────────────────
LOG_LEVEL=info

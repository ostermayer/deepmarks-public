{
  "name": "deepmarks-payment-proxy",
  "version": "0.1.0",
  "description": "Box A payment service — Lightning invoicing via Voltage, LNURL-pay for zap@deepmarks.org, NIP-57 zap receipts, email-linked session auth",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:pinboard": "tsx src/seed/cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@fastify/cors": "^11.2.0",
    "@noble/hashes": "^1.4.0",
    "@simplewebauthn/server": "^13.3.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lightning": "^10.19.0",
    "nostr-tools": "^2.7.2",
    "pino-pretty": "^13.1.3",
    "resend": "^3.4.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}

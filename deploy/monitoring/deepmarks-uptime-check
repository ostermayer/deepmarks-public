#!/usr/bin/env bash
# deepmarks-uptime-check — sovereign external pinger.
#
# Lives on Box C and pings the three boxes. Alerts on three consecutive
# failures so a transient blip doesn't email. State (consecutive failure
# counter) lives in /var/lib/deepmarks-uptime/.
#
# Targets:
#   - Box A: GET https://api.deepmarks.org/health        (Caddy + payment-proxy)
#   - Box B: archive-worker liveness via Box A redis     (queue heartbeat
#                                                         OR explicit health
#                                                         marker the worker
#                                                         updates each loop)
#   - Box C: GET http://127.0.0.1:4100/health            (bunker, local)
#
# Run via cron every 5 min. The ALERT KEYS are per-target so a Box A
# outage doesn't suppress a separate Box C outage.

set -euo pipefail

STATE_DIR=/var/lib/deepmarks-uptime
THRESHOLD=3                # consecutive failures before alerting
TIMEOUT=10                 # per-probe seconds

mkdir -p "$STATE_DIR"
chmod 700 "$STATE_DIR"

# ── helpers ────────────────────────────────────────────────────────────

bump_failure() {
  local target="$1"
  local f="$STATE_DIR/$target.fail"
  local n=$(( $(cat "$f" 2>/dev/null || echo 0) + 1 ))
  echo "$n" > "$f"
  echo "$n"
}

reset_failure() {
  local target="$1"
  local f="$STATE_DIR/$target.fail"
  if [ -s "$f" ]; then
    local was
    was=$(cat "$f")
    rm -f "$f"
    if [ "$was" -ge "$THRESHOLD" ]; then
      # Recovery: emit an info alert so the operator sees the outage closed.
      deepmarks-alert info "uptime-recover-$target" \
        "$target recovered" \
        "Probe success after $was consecutive failures."
    fi
  fi
}

probe_http() {
  local name="$1"
  local url="$2"
  if curl -sS -o /dev/null --max-time "$TIMEOUT" -w '%{http_code}\n' "$url" 2>/dev/null \
      | grep -q '^20[02]$'; then
    reset_failure "$name"
  else
    n=$(bump_failure "$name")
    if [ "$n" -ge "$THRESHOLD" ]; then
      deepmarks-alert critical "uptime-$name" \
        "$name unreachable for $n consecutive probes" \
        "Probe URL: $url" \
        "Check Caddy + service container on the target box."
    fi
  fi
}

probe_redis_heartbeat() {
  # Box B archive-worker doesn't expose HTTP. We probe by checking that
  # the worker has touched a heartbeat key in Box A's Redis recently.
  # Worker writes `dm:archive:worker-heartbeat` every 30s; >5 min stale
  # = stuck.
  local name="box-b-worker"
  local key="${ARCHIVE_WORKER_HEARTBEAT_KEY:-dm:archive:worker-heartbeat}"
  local redis_host="${REDIS_HOST:-10.0.0.2}"
  local redis_port="${REDIS_PORT:-6379}"
  local redis_pass="${REDIS_PASSWORD:-}"

  local age
  if [ -n "$redis_pass" ]; then
    age=$(redis-cli -h "$redis_host" -p "$redis_port" -a "$redis_pass" --no-auth-warning \
        OBJECT IDLETIME "$key" 2>/dev/null || echo "missing")
  else
    age=$(redis-cli -h "$redis_host" -p "$redis_port" \
        OBJECT IDLETIME "$key" 2>/dev/null || echo "missing")
  fi

  if [ "$age" = "missing" ] || ! [ "$age" -ge 0 ] 2>/dev/null; then
    n=$(bump_failure "$name")
    if [ "$n" -ge "$THRESHOLD" ]; then
      deepmarks-alert critical "uptime-$name" \
        "Box B archive-worker heartbeat missing" \
        "Redis key '$key' has no recent activity ($n consecutive checks)." \
        "Worker may be down or wedged. SSH to Box B and check: docker logs box-b-archive-worker-1"
    fi
  elif [ "$age" -gt 300 ]; then  # 5 min stale
    n=$(bump_failure "$name")
    if [ "$n" -ge "$THRESHOLD" ]; then
      deepmarks-alert critical "uptime-$name" \
        "Box B archive-worker heartbeat stale (${age}s)" \
        "Redis key '$key' last updated ${age} seconds ago." \
        "Worker likely deadlocked. Recreate: docker compose up -d --force-recreate archive-worker"
    fi
  else
    reset_failure "$name"
  fi
}

# ── main ───────────────────────────────────────────────────────────────

probe_http "box-a"      "https://api.deepmarks.org/health"
probe_redis_heartbeat
probe_http "box-c"      "http://127.0.0.1:4100/health"

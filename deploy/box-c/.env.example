# Box C — copy to .env on the box, fill in, chmod 600.
# NEVER commit the populated .env.

# The single payment-proxy pubkey this bunker will honor. Generate on
# Box A with:
#   node -e "const {getPublicKey}=require('nostr-tools');const sk=require('crypto').randomBytes(32);console.log(getPublicKey(sk))"
# (or equivalent) and set the matching nsec in Box A's BUNKER_CLIENT_NSEC.
# Rotating is a code-free step: update this value + the matching nsec on
# Box A, then `docker compose up -d` both boxes. Old client pubkey's
# requests will start getting rejected immediately.
BUNKER_CLIENT_PUBKEY=

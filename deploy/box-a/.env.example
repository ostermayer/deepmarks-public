# Box A — copy to .env on the box, fill in real values, chmod 600.
# NEVER commit the populated .env.

# ─── Voltage (Lightning) ────────────────────────────────────────────────
# Use the gRPC socket (port 10009), not REST (8080).
VOLTAGE_REST_URL=your-node.m.voltageapp.io:10009
# Invoice-only macaroon, hex-encoded.  xxd -p invoice.macaroon | tr -d '\n'
VOLTAGE_INVOICE_MACAROON=

# ─── nsecBunker client (Box C talks NIP-46 over Box A's strfry) ─────────
# Payment-proxy doesn't hold the brand or personal nsec anymore; Box C
# does, inside nsecBunker. Payment-proxy authenticates to the bunker
# using an ephemeral client keypair (below). The bunker authorizes this
# pubkey to sign only specific kinds on specific identities. Rotate
# BUNKER_CLIENT_NSEC by generating a new pair + updating
# BUNKER_CLIENT_PUBKEY on Box C's .env + redeploying both.
BUNKER_CLIENT_NSEC=
# Ephemeral NSEC above derives to this pubkey. Put the same pubkey in
# Box C's BUNKER_CLIENT_PUBKEY. Generate fresh with:
#   node -e "const {getPublicKey,generateSecretKey,nip19}=require('nostr-tools'); \
#            const sk=generateSecretKey(); \
#            console.log('nsec:',nip19.nsecEncode(sk),'\npub:',getPublicKey(sk))"
BUNKER_RELAY_URL=ws://strfry:7777
BUNKER_BRAND_PUBKEY=
BUNKER_PERSONAL_PUBKEY=

# ─── JWT signing for API keys ───────────────────────────────────────────
JWT_SECRET=

# ─── Object storage (Linode bucket) ─────────────────────────────────────
S3_ENDPOINT=https://us-southeast-1.linodeobjects.com
S3_REGION=us-southeast-1
S3_BUCKET=deepmarks
# Separate public-read bucket for cached site favicons. Keep distinct from
# the main bucket because favicons are served unauthenticated via redirect.
FAVICON_BUCKET=deepmarks-favicons
# Public base URL the /favicon endpoint redirects browsers to. If unset
# we derive it from S3_ENDPOINT + FAVICON_BUCKET (virtual-host style).
FAVICON_PUBLIC_BASE=
# Private bucket for passkey-encrypted user nsec ciphertext. The server
# never holds decryption keys — these blobs are AES-GCM ciphertext
# encrypted with a key derived from each user's passkey via WebAuthn PRF.
LINODE_CIPHERTEXT_BUCKET=ciphertext
LINODE_ACCESS_KEY=
LINODE_SECRET_KEY=

# ─── Passkey / WebAuthn relying party ──────────────────────────────────
# Must match the origin of the frontend that calls navigator.credentials.*.
# Defaults to deepmarks.org / https://deepmarks.org — override on staging.
PASSKEY_RP_ID=deepmarks.org
PASSKEY_RP_NAME=Deepmarks
PASSKEY_ORIGIN=https://deepmarks.org

# ─── Blossom write allowlist (archive worker pubkey, hex) ───────────────
ARCHIVE_WORKER_PUBKEY=

# ─── Archive worker callback secret ─────────────────────────────────────
# Shared with archive-worker on Box B. payment-proxy uses this to verify
# HMAC on /archive/callback. MUST match the same key on Box B's .env or
# every archive job's terminal status update is dropped (route 503s).
# Generate with: openssl rand -hex 32
WORKER_CALLBACK_SECRET=

# ─── Redis ──────────────────────────────────────────────────────────────
# REDIS_PASSWORD: raw value used by redis-server --requirepass
# REDIS_PASSWORD_URLENC: same value, URL-encoded for the redis:// URL
#   (only differs if your password contains URL-unsafe chars).
REDIS_PASSWORD=
REDIS_PASSWORD_URLENC=

# ─── Meilisearch ────────────────────────────────────────────────────────
MEILI_MASTER_KEY=

# ─── CORS for the frontend ──────────────────────────────────────────────
# Comma-separated origins. The frontend lives on Cloudflare Pages — both
# the bare apex (after CF Pages takes deepmarks.org) and the .pages.dev
# preview URL should be allowed. Add other previews as needed.
CORS_ORIGIN=https://deepmarks.org,https://deepmarks.pages.dev

# ─── Operational email (Resend) — admin notifications only ─────────────
# Used to notify the operator on CSAM / abuse reports. Leave unset in
# dev; payment-proxy logs email messages to stdout when no key is set.
RESEND_API_KEY=
EMAIL_FROM=Deepmarks <noreply@deepmarks.org>
# Addresses that receive abuse / CSAM notifications. Default to the
# deepmarks.org aliases if unset.
EMAIL_ABUSE=
EMAIL_CSAM=

# ─── BTCPay (lifetime-tier invoicing) ───────────────────────────────────
# Leave empty to disable the lifetime upgrade flow.
BTCPAY_URL=https://btcpay0.voltageapp.io
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

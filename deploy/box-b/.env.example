# Box B — copy to .env on the box, fill in real values, chmod 600.
# NEVER commit the populated .env.

# ─── Archive worker Nostr identity ──────────────────────────────────────
# This pubkey must also appear in Box A's ARCHIVE_WORKER_PUBKEY (Blossom allowlist).
ARCHIVE_WORKER_NSEC=

# ─── Shared secret for worker → payment-proxy callbacks ─────────────────
# Match WORKER_CALLBACK_SECRET on Box A (same value in both .env files).
WORKER_CALLBACK_SECRET=

# ─── Redis password (must match Box A) ──────────────────────────────────
REDIS_PASSWORD=
REDIS_PASSWORD_URLENC=
